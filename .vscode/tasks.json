{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Twistaway: Start Android emulator",
      "type": "process",
      "command": "bun",
      "args": ["run", "emulator:android"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Twistaway: Build release APK",
      "type": "process",
      "command": "bun",
      "args": ["run", "build:android"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Twistaway: Build debug APK",
      "type": "process",
      "command": "bun",
      "args": ["run", "build:android:debug"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    }
  ]
}
