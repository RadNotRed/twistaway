# Generate with: openssl rand -hex 32
APP_ENCRYPTION_SECRET=replace-with-at-least-32-random-bytes

# The API is published only on localhost by default. Cloudflare Tunnel reaches
# it over the Compose network, so this does not need to be 0.0.0.0.
API_BIND_ADDRESS=127.0.0.1
API_PORT=4180
SESSION_DAYS=30

# Comma-separated browser origins. Native Android/iOS requests do not send a
# browser Origin header and remain supported.
CORS_ORIGINS=https://twistaway.app,https://www.twistaway.app,https://app.twistaway.app

# Create a remotely managed tunnel in Cloudflare, then paste its token here.
# Never commit the populated .env file.
CLOUDFLARE_TUNNEL_TOKEN=
